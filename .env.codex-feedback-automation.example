# Project-local environment for Codex feedback automation.
# Copy to `.env.codex-feedback-automation.local` and fill values.

FEEDBACK_API_BASE_URL="http://opentrifi.duckdns.org"
FEEDBACK_ADMIN_USER="admin"
FEEDBACK_ADMIN_PASSWORD="<set-admin-password>"
# Set this only when backend requires X-API-Key:
FEEDBACK_API_TOKEN="<set-api-token-or-empty>"

# Required for git push on your network:
http_proxy="http://127.0.0.1:10808"
https_proxy="http://127.0.0.1:10808"
