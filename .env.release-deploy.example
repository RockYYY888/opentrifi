ASSET_TRACKER_SERVER_ORIGIN="https://opentrifi.duckdns.org"
ASSET_TRACKER_SERVER_PATH="~/finance--tracker"
ASSET_TRACKER_ADMIN_API_KEY="<set-admin-api-key>"
